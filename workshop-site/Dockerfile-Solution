# Workshop Dockerfile — reference version
# Use this as your guide. The students will fill in the blanks in Dockerfile.starter

# Step 1: Start from a base image
FROM node:18-alpine

# Step 2: Set the working directory inside the container
WORKDIR /app

# Step 3: Copy package files first (for Docker layer caching)
COPY package*.json ./

# Step 4: Install dependencies
RUN npm install

# Step 5: Copy the rest of the application code
COPY . .

# Step 6: Tell Docker which port the app runs on
EXPOSE 3000

# Step 7: Define how to start the app
CMD ["node", "server.js"]
